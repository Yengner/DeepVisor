{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/(root)/integration/meta/unsuccessful",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions/**",
    "src/_archive/**",
    "src/app/(auth)/(unused)/**",
    "src/app/(auth)/(unused)/**/*",
    "src/components/campaigns/create/flows/manual/CustomCampaignFlow.tsx",
    "src/components/campaigns/create/flows/manual/MetaCampaignBuilder.tsx",
    "src/components/public/depricated/Benefits/**",
    "src/components/public/depricated/CTA.tsx",
    "src/components/public/depricated/FAQ.tsx",
    "src/components/public/depricated/Footer.tsx",
    "src/components/public/depricated/FreeEstimateButton.tsx",
    "src/components/public/depricated/Header.tsx",
    "src/components/public/depricated/Hero.tsx",
    "src/components/public/depricated/Pricing/**",
    "src/components/public/depricated/Stats.tsx",
    "src/components/public/depricated/Testimonials.tsx"
  ]
}
